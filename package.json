{
  "name": "presto",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/contracts",
    "packages/sdk-core",
    "packages/sdk-runtime"
  ],
  "description": "Desktop shell for Presto Pro Tools workflows",
  "author": "Luminous Layers",
  "copyright": "Copyright (c) 2026 Loyan Li",
  "scripts": {
    "clean:local": "node scripts/clean-local-artifacts.mjs",
    "test": "npm run test:node && npm run test:python",
    "test:node": "node --test frontend/electron/test/*.test.mjs frontend/host/test/*.test.mjs frontend/tauri/test/*.test.mjs host-plugin-runtime/test/*.test.mjs packages/contracts/test/*.test.mjs plugins/official/*/test/*.test.mjs",
    "test:python": "cd backend && python3 -m pytest presto/tests",
    "tauri:prepare:all": "npm run tauri:build:frontend && npm run tauri:prepare:python && npm run tauri:prepare:resources",
    "tauri:prepare:python": "node scripts/prepare-tauri-python.mjs",
    "tauri:prepare:resources": "node scripts/prepare-tauri-resources.mjs",
    "tauri:build:frontend": "node scripts/build-tauri-frontend.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/package-tauri-build.mjs",
    "tauri:build:arm64": "PRESTO_TAURI_TARGET=aarch64-apple-darwin node scripts/package-tauri-build.mjs",
    "tauri:build:x64": "PRESTO_TAURI_TARGET=x86_64-apple-darwin node scripts/package-tauri-build.mjs",
    "sync:icon": "bash scripts/prepare_icon.sh",
    "developer:smoke:read": "npm run tauri:build:frontend",
    "developer:smoke:write": "npm run tauri:build:frontend",
    "developer:smoke:strip-silence": "npm run tauri:build:frontend",
    "developer:smoke:core-io": "npm run tauri:build:frontend",
    "stage1:smoke:track-write": "npm run tauri:build:frontend",
    "stage1:smoke:core-io": "npm run developer:smoke:core-io",
    "stage1:smoke": "npm run developer:smoke:read && npm run developer:smoke:write && npm run stage1:smoke:core-io && npm run developer:smoke:strip-silence && npm run stage1:smoke:track-write"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tauri-apps/api": "^2.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "esbuild": "^0.25.0"
  }
}
