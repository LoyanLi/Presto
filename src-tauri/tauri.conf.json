{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Presto",
  "version": "0.3.0-alpha.2",
  "identifier": "com.loyan.presto",
  "build": {
    "beforeBuildCommand": "npm run tauri:build:frontend && npm run tauri:build:sidecar && npm run tauri:prepare:resources",
    "beforeDevCommand": "npm run tauri:build:frontend && npm run tauri:build:sidecar && npm run tauri:prepare:resources",
    "frontendDist": "../build/tauri/renderer"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/extensions/**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Presto",
        "visible": false,
        "backgroundColor": [12, 14, 23, 255],
        "width": 1180,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      },
      {
        "label": "splashscreen",
        "title": "Presto",
        "url": "/splashscreen.html",
        "center": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "width": 420,
        "height": 280,
        "backgroundColor": [12, 14, 23, 255]
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "entitlements": "entitlements.mac.plist"
    },
    "resources": [
      "../build/sidecar",
      "../build/runtime-resources/backend",
      "../build/runtime-resources/plugins",
      "../build/runtime-resources/frontend"
    ]
  }
}
