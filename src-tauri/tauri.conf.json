{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Presto",
  "version": "0.3.4",
  "identifier": "com.loyan.presto",
  "build": {
    "beforeBuildCommand": "npm run tauri:prepare:all",
    "beforeDevCommand": "npm run tauri:prepare:all",
    "frontendDist": "../build/tauri/renderer"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/extensions/**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Presto",
        "visible": true,
        "backgroundColor": [12, 14, 23, 255],
        "width": 1180,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "entitlements": "entitlements.mac.plist"
    },
    "resources": {
      "resources/build/": "build/",
      "resources/backend/": "backend/",
      "resources/plugins/": "plugins/",
      "resources/frontend/": "frontend/"
    }
  }
}
